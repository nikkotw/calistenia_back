# Server Configuration
NODE_ENV=development
HOST=localhost
PORT=3000

# Database Configuration
DATABASE_URL="mysql://root:password@localhost:3306/calistenia_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"
JWT_EXPIRES_IN="7d"

# Frontend Configuration
FRONTEND_URL="http://localhost:5173"

# Storage provider: local | s3
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./uploads"

# AWS S3 Configuration (optional, only if STORAGE_PROVIDER="s3")
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-aws-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# S3_BUCKET_NAME="your-s3-bucket-name"
# S3_BUCKET_REGION="us-east-1"

# File Upload Configuration
MAX_FILE_SIZE=52428800
# 50MB = 50 * 1024 * 1024 = 52428800 bytes
ALLOWED_FILE_TYPES="video/mp4,video/webm,video/ogg,image/jpeg,image/jpg,image/png"

# Email Configuration (Optional)
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT=587
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-app-password"

# External API Keys (Optional)
# STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
# STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"